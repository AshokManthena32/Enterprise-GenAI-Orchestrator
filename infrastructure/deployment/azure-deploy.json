{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for all resources."
      }
    },
    "aiSearchServiceName": {
      "type": "string",
      "defaultValue": "enterprise-search-genai",
      "metadata": {
        "description": "The name of the Azure AI Search service."
      }
    },
    "openAiServiceName": {
      "type": "string",
      "defaultValue": "enterprise-openai-genai",
      "metadata": {
        "description": "The name of the Azure OpenAI service."
      }
    }
  },
  "variables": {
    "searchSku": "standard",
    "openAiSku": "S0"
  },
  "resources": [
    {
      "type": "Microsoft.CognitiveServices/accounts",
      "apiVersion": "2023-05-01",
      "name": "[parameters('openAiServiceName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[variables('openAiSku')]"
      },
      "kind": "OpenAI",
      "properties": {
        "customSubDomainName": "[parameters('openAiServiceName')]",
        "publicNetworkAccess": "Enabled"
      }
    },
    {
      "type": "Microsoft.Search/searchServices",
      "apiVersion": "2023-11-01",
      "name": "[parameters('aiSearchServiceName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[variables('searchSku')]"
      },
      "properties": {
        "replicaCount": 1,
        "partitionCount": 1,
        "hostingMode": "default"
      }
    }
  ],
  "outputs": {
    "openAiEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts', parameters('openAiServiceName')), '2023-05-01').endpoint]"
    },
    "searchServiceEndpoint": {
      "type": "string",
      "value": "[format('https://{0}.search.windows.net', parameters('aiSearchServiceName'))]"
    }
  }
}
